# =============================================================================
# Azure OpenAI Realtime API Configuration (Raw WebSocket mode)
# =============================================================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-realtime-mini
AZURE_OPENAI_API_KEY=your-api-key-here

# Set to "true" to use Microsoft Entra ID instead of API key
AZURE_USE_ENTRA_ID=true

# Realtime API mode: "ga" for gpt-realtime-mini, gpt-realtime, gpt-realtime-1.5
REALTIME_API_MODE=ga

# =============================================================================
# Azure Voice Live SDK Configuration (Foundry mode)
# =============================================================================
AZURE_VOICELIVE_ENDPOINT=https://your-resource.services.ai.azure.com/
AZURE_VOICELIVE_MODEL=gpt-realtime-mini

# =============================================================================
# Foundry Agent Configuration (Agent mode)
# =============================================================================
# Full project endpoint for agent creation script
PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project-name

# Agent identification
FOUNDRY_AGENT_NAME=MyVoiceAgent
FOUNDRY_PROJECT_NAME=your-project-name
FOUNDRY_AGENT_MODEL=gpt-5-mini

# Optional agent settings
# FOUNDRY_AGENT_VERSION=          # Specific agent version (defaults to latest)
# FOUNDRY_CONVERSATION_ID=        # Resume an existing conversation
# FOUNDRY_RESOURCE_OVERRIDE=      # Override resource routing

# =============================================================================
# Optional: Override region display (auto-detected from endpoint if not set)
# =============================================================================
# AZURE_REGION=canadaeast
